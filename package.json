{
  "name": "destates-backend",
  "version": "1.0.0",
  "description": "Destates Real Estate API Server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "postinstall": "prisma generate --config prisma/prisma.config.ts",
    "build": "prisma generate --config prisma/prisma.config.ts && tsc && npx tsc --esModuleInterop --skipLibCheck --module commonjs --target ES2020 --resolveJsonModule --outDir dist/prisma prisma/seed.ts",
    "start": "node dist/index.js",
    "start:prod": "prisma migrate deploy --config prisma/prisma.config.ts && node dist/prisma/seed.js && node dist/index.js",
    "seed": "node dist/prisma/seed.js",
    "db:migrate": "prisma migrate dev --config prisma/prisma.config.ts",
    "db:seed": "prisma db seed --config prisma/prisma.config.ts",
    "db:studio": "prisma studio --config prisma/prisma.config.ts"
  },
  "keywords": [],
  "author": "Destates Private Limited",
  "license": "ISC",
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "razorpay": "^2.9.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^6.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "prisma": "^7.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
