# Database
# IMPORTANT: URL-encode special characters in passwords (@ → %40, # → %23, etc.)
DATABASE_URL="postgresql://postgres:your-password@localhost:5432/destates"

# Set to "true" only for external DB providers (Supabase, Neon, Railway) that require SSL.
# Dokploy internal databases do NOT need SSL — leave unset or "false".
# DATABASE_SSL="false"

# Authentication
JWT_SECRET="generate-a-strong-random-secret-here"

# Server
PORT=5000
NODE_ENV="development"

# CORS — comma-separated list of allowed origins
# In development this is ignored (all origins allowed)
# In production, list all domains that should access the API
ALLOWED_ORIGINS="https://destates.in,https://www.destates.in"
