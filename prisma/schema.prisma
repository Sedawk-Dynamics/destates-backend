generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  phone         String?
  role          Role           @default(USER)
  investments   Investment[]
  insurances    UserInsurance[]
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

enum Role {
  USER
  ADMIN
}

model Property {
  id                String         @id @default(cuid())
  name              String
  location          String
  city              String
  price             Float          // Total property value (for display)
  expectedROI       Float
  monthlyYield      Float?
  area              Int
  totalFractions    Int            // Total fractional parts of this property
  availableFractions Int           // How many fractions are still available
  pricePerFraction  Float          // Minimum price per fraction (set by admin)
  status            PropertyStatus @default(AVAILABLE)
  description       String
  highlights        String[]
  images            String[]
  reraRegistered    Boolean        @default(true)
  readyToMove       Boolean        @default(false)
  disabled          Boolean        @default(false)
  type              String         @default("Residential")

  // ROI Calculator settings (admin-controlled)
  roiCalculatorEnabled  Boolean @default(true)
  projectionYears       Int     @default(5)
  capitalAppreciation   Float   @default(5)    // Annual capital appreciation %
  rentalYieldMonths     Int     @default(12)   // Months of rental yield per year
  lockInPeriod          Int     @default(0)    // Lock-in period in months (0 = no lock-in)
  minFractions          Int     @default(1)    // Min fractions user can buy
  maxFractions          Int?                   // Max fractions per user (null = no limit)

  investments    Investment[]
  insurancePlans InsurancePlan[] @relation("PropertyInsurancePlans")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PropertyStatus {
  AVAILABLE
  LIMITED
  SOLD_OUT
}

model Investment {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId      String
  property        Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  fractions       Int               // Number of fractions purchased
  amountPaid      Float             // Total amount paid
  pricePerFraction Float            // Price per fraction at time of purchase
  status          InvestmentStatus  @default(PENDING)

  // Razorpay fields
  razorpayOrderId   String  @unique
  razorpayPaymentId String?
  razorpaySignature String?

  insurances UserInsurance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum InvestmentStatus {
  PENDING
  COMPLETED
  FAILED
}

model LandPlot {
  id           String   @id @default(cuid())
  name         String
  location     String
  city         String
  totalArea    Int
  pricePerSqft Float
  minArea      Int      @default(100)
  amenities    String[]
  description  String
  images       String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PGListing {
  id           String   @id @default(cuid())
  name         String
  location     String
  city         String
  monthlyRent  Float
  roomType     String
  amenities    String[]
  contactPhone String
  description  String
  images       String[]
  available    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactInquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model InsurancePlan {
  id             String          @id @default(cuid())
  name           String          // e.g. "Basic", "Standard", "Premium"
  monthlyPremium Float
  coverage       String          // Description of what's covered
  active         Boolean         @default(true)
  properties     Property[]      @relation("PropertyInsurancePlans")
  userInsurances UserInsurance[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model UserInsurance {
  id                String          @id @default(cuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  investmentId      String
  investment        Investment      @relation(fields: [investmentId], references: [id], onDelete: Cascade)
  insurancePlanId   String
  insurancePlan     InsurancePlan   @relation(fields: [insurancePlanId], references: [id], onDelete: Cascade)
  amountPaid        Float
  status            InsuranceStatus @default(ACTIVE)
  razorpayOrderId   String          @unique
  razorpayPaymentId String?
  razorpaySignature String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

enum InsuranceStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Testimonial {
  id          String  @id @default(cuid())
  name        String
  designation String
  company     String
  content     String
  rating      Int     @default(5)
  avatarUrl   String?
}
